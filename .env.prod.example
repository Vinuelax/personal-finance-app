# Copy to .env.prod on the box and fill in real values. Do NOT commit .env.prod.
# Used both for compose interpolation (--env-file) and as the api/migrate env_file.

# Image tag to deploy (must match what was pushed to GHCR).
IMAGE_TAG=latest

# --- Postgres (in-container) ---
POSTGRES_USER=postgres
POSTGRES_DB=pfa
POSTGRES_PASSWORD=change-me-strong-password

# --- Backend ---
ENVIRONMENT=production
# Host/password must match the Postgres settings above (service name = postgres).
DATABASE_URL=postgresql+psycopg://postgres:change-me-strong-password@postgres:5432/pfa
# 64 hex chars: openssl rand -hex 32
AUTH_SECRET=change-me-auth-secret
AUTH_ISSUER=pennypilot
# Shared secret for the OCR callback (only needed if you wire real OCR later).
INTERNAL_SERVICE_TOKEN=change-me-internal-token
# Comma-separated; required when ENVIRONMENT != development.
BACKEND_CORS_ORIGINS=https://app.vinuelax.cl
# Optional overrides:
# DEFAULT_CURRENCY=CLP
# AUTH_TOKEN_EXPIRE_MINUTES=43200

# --- Frontend (baked into the static bundle at build time) ---
NEXT_PUBLIC_API_BASE_URL=https://app.vinuelax.cl/api/v1
